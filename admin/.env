# ── Server ────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:3000
VITE_SUPABASE_URL=https://ydndrkxchypzaywhbywg.supabase.co
PORT=3000

# ── Database MySQL XAMPP ──────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=dimsum_house

# ── CORS: izinkan kedua frontend ─────────────────────────────────
