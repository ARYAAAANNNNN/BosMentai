# appdimsum → http://localhost:5173
CORS_ORIGIN_ADMIN=http://localhost:5174
CORS_ORIGIN_APP=http://localhost:5173

# ── AYCE flat rate per pesanan (dipakai statsController) ─────────
FLAT_RATE=75000